import java.util.HashMap;

public class Main {
public static void main(String[] args) {
int[] arr = {1, 2, 1, 3, 2, 1};
HashMap<Integer, Integer> freq = new HashMap<>();
for (int num : arr) {
if (freq.containsKey(num)) {
freq.put(num, freq.get(num) + 1);
}
else {
freq.put(num, 1);
}
}
System.out.println(freq);
}
}
